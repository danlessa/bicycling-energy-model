# Raw FIT files carry a GPS track — kept local for testing, not committed.
# Drop an anonymised .fit here and force-add it if you want a committed fixture.
*.fit

# Downloaded activity tracks (RideWithGPS JSON / Strava originals) carry GPS —
# keep local, never commit. See data/activities/README.md. The fetcher and the
# README itself are committable; the raw tracks and manifest are not.
data/activities/rwgps/
data/activities/strava/
data/activities/*.json
data/activities/*.csv

# Censo Hidrográfico activity tracks (Strava/RWGPS originals) — GPS, never commit.
# Whole dir: raw tracks + manifest.json + any derived csv.
data/activities/censohidrografico/

# P. Paz's Strava history export (second rider, shared with consent) — GPS +
# third-party personal data, never commit. Whole dir: fit.gz/gpx originals +
# any manifest/derived files.
data/activities/strava_ppaz/

# The censo spreadsheet itself carries activity links / attendance — keep local.
data/censo-hidrografico.xlsx

# The longões spreadsheet carries private activity links + physiology (weight/HR).
# It was purged from history (2026-07); it must NEVER be re-committed. fetch.py /
# build_model_inputs.py read it from this path locally.
data/longoes.xlsx

# Per-ride lon/lat coordinate CSVs written by research/dem/extract_coords.mjs — GPS.
research/dem/coords/

# OS / editor cruft
.DS_Store
.vscode/
__pycache__/
*.pyc
.env